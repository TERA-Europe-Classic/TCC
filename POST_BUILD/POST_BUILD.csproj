<!--
  Classic+ read-only fork: the upstream POST_BUILD packaged TCC as a
  tera-toolbox module (index.js + module.json + manifest-generator.js)
  so Foglio could run TCC inside his toolbox. Classic+ has its own
  ClassicPlusSniffer (127.0.0.1:7803) and never loads as a module, so
  all of that is dead weight. Keep the empty csproj to preserve the
  solution topology; remove the PostBuildEvent that referenced the
  hardcoded X:\tools\manifest-generator.js.
-->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8</TargetFramework>
    <LangVersion>12</LangVersion>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <PreserveCompilationContext>false</PreserveCompilationContext>
    <Configurations>Debug;Release;DebugToolbox</Configurations>
  </PropertyGroup>
</Project>
